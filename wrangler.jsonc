{
  // https://developers.cloudflare.com/workers/wrangler/configuration/
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "octrends",
  "main": "worker/index.ts",
  "compatibility_date": "2026-02-10",
  "observability": {
    "enabled": true,
  },
  "kv_namespaces": [
    {
      "binding": "OPEN_COLLECTIVE_TRANSACTIONS",
      "id": "56471e1b160749c8a396d1f2f140a7d7",
    },
  ],
  "routes": [
    {
      "pattern": "octrends.bjornlu.com",
      "custom_domain": true,
    },
  ],
  "env": {
    "production": {
      "kv_namespaces": [
        {
          "binding": "OPEN_COLLECTIVE_TRANSACTIONS",
          "id": "56471e1b160749c8a396d1f2f140a7d7",
        },
      ],
      "assets": {
        "directory": "./dist",
        "binding": "ASSETS",
        "not_found_handling": "single-page-application",
      },
    },
  },
}
